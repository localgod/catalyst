@startuml rel-directional
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Container.puml
title Relationships — directional hints (_U/_D/_L/_R)
System(hub, "Hub")
System(n, "North")
System(s, "South")
System(e, "East")
System(w, "West")
Rel_U(hub, n, "up")
Rel_D(hub, s, "down")
Rel_L(hub, w, "left")
Rel_R(hub, e, "right")
@enduml
