@startuml c4-deployment
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Deployment.puml

title Deployment — webshop production

Deployment_Node(aws, "AWS eu-west-1", "Cloud region") {
  Deployment_Node(cluster, "EKS cluster", "Kubernetes 1.30") {
    Container(api, "API service", "Go 1.22", "REST API")
    ContainerDb(cache, "Redis", "7.2", "Session cache")
  }

  Deployment_Node(rds, "RDS Postgres", "db.m5.large") {
    ContainerDb(db, "webshop", "Postgres 16", "Primary store")
  }
}

Deployment_Node(cdn, "Cloudflare", "Global edge")

Rel(cdn, api, "Proxies HTTPS", "443")
Rel(api, cache, "Reads/writes", "redis")
Rel(api, db, "SQL", "5432")
@enduml
