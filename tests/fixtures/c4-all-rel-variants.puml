@startuml all-rel-variants
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Container.puml

title Exercise every relationship primitive

System(a, "A")
System(b, "B")
System(c, "C")
System(d, "D")

Rel(a, b, "plain Rel")
Rel(a, b, "plain Rel 4-arg", "tech")
Rel_Back(a, b, "Rel_Back")
Rel_Neighbor(a, b, "Rel_Neighbor")
Rel_Back_Neighbor(a, b, "Rel_Back_Neighbor")

Rel_U(a, c, "Rel_U")
Rel_D(a, c, "Rel_D")
Rel_L(a, c, "Rel_L")
Rel_R(a, c, "Rel_R")

Rel_Up(a, d, "Rel_Up")
Rel_Down(a, d, "Rel_Down")
Rel_Left(a, d, "Rel_Left")
Rel_Right(a, d, "Rel_Right")

BiRel(b, c, "BiRel")
BiRel_Neighbor(b, c, "BiRel_Neighbor")
BiRel_U(b, d, "BiRel_U")
BiRel_Up(c, d, "BiRel_Up")
@enduml
